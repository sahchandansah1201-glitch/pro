{
  "openapi": "3.1.0",
  "info": {
    "title": "Dermatolog Pro self-hosted API · Stage 9N-9Z",
    "version": "9N-9Z-device-bridge-lifecycle-assurance",
    "description": "Self-hosted Device Bridge lifecycle assurance contract. The endpoint exposes safe operator metadata only and keeps the product independent from managed runtime/database services."
  },
  "servers": [{ "url": "/" }],
  "paths": {
    "/api/v1/device-bridge-worker/lifecycle-assurance": {
      "get": {
        "summary": "Read Device Bridge lifecycle assurance package",
        "operationId": "getDeviceBridgeLifecycleAssurance",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Safe lifecycle assurance metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceBridgeLifecycleAssuranceResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthRequired" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "responses": {
      "AuthRequired": {
        "description": "Authentication required"
      },
      "Forbidden": {
        "description": "system_admin role required"
      }
    },
    "schemas": {
      "DeviceBridgeLifecycleAssuranceResponse": {
        "type": "object",
        "required": ["stage", "source", "assurance", "generatedAt", "correlationId"],
        "properties": {
          "stage": { "const": "9N-9Z" },
          "source": { "const": "postgres" },
          "assurance": { "$ref": "#/components/schemas/DeviceBridgeLifecycleAssurance" },
          "auth": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "roles": { "type": "array", "items": { "type": "string" } },
              "allClinics": { "type": "boolean" }
            }
          },
          "generatedAt": { "type": "string" },
          "correlationId": { "type": "string" }
        }
      },
      "DeviceBridgeLifecycleAssurance": {
        "type": "object",
        "required": ["status", "completionPercent", "summary", "lifecyclePolicy", "handoff", "stages", "gates", "productBoundary"],
        "properties": {
          "status": { "type": "string", "enum": ["ready", "attention"] },
          "completionPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
          "generatedAt": { "type": "string" },
          "summary": {
            "type": "object",
            "properties": {
              "bridgeCount": { "type": "integer" },
              "staleWorkers": { "type": "integer" },
              "failedCommands": { "type": "integer" },
              "stuckCommands": { "type": "integer" },
              "retryableCommands": { "type": "integer" },
              "cancellableCommands": { "type": "integer" },
              "queuePressure": { "type": "integer" },
              "fleetAttention": { "type": "integer" },
              "inheritedAttentionGates": { "type": "integer" },
              "auditEvents": { "type": "integer" },
              "assuranceDebt": { "type": "integer" },
              "upgradePressure": { "type": "integer" },
              "maintenanceDue": { "type": "boolean" },
              "retentionReviewDue": { "type": "boolean" }
            }
          },
          "lifecyclePolicy": {
            "type": "object",
            "properties": {
              "maintenanceReviewCadence": { "type": "string" },
              "workerUpgradeReviewCadence": { "type": "string" },
              "auditRetentionReviewDays": { "type": "integer" },
              "closureEvidenceStorage": { "type": "string" },
              "liveOutcomeKnownToRepository": { "type": "boolean" },
              "workerHeartbeatReviewMinutes": { "type": "integer" },
              "commandQueueReviewMinutes": { "type": "integer" }
            }
          },
          "handoff": {
            "type": "object",
            "properties": {
              "previousBatch": { "type": "string" },
              "currentBatch": { "type": "string" },
              "originalHypothesis": { "type": "string" },
              "nextBatchHypothesis": { "type": "string" },
              "includedStages": { "type": "array", "items": { "type": "string" } },
              "assuranceOwner": { "type": "string" },
              "promptOnlyAfterMergeToMain": { "type": "boolean" }
            }
          },
          "stages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AssuranceStage" }
          },
          "gates": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AssuranceGate" }
          },
          "inheritedReliability": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "completionPercent": { "type": "integer" },
              "gateCount": { "type": "integer" },
              "attentionGateCount": { "type": "integer" }
            }
          },
          "productBoundary": {
            "type": "object",
            "properties": {
              "managedRuntimeDependency": { "const": "none" },
              "managedDatabaseDependency": { "const": "none" },
              "browserHardwareApis": { "const": false },
              "payloadVisibility": { "const": "backend-only" },
              "rawPatientDataInReports": { "const": false },
              "signedUrlExposure": { "const": false },
              "storagePathExposure": { "const": false },
              "externalRuntimeCalls": { "const": false },
              "liveSecretsInReports": { "const": false }
            }
          }
        }
      },
      "AssuranceStage": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" },
          "owner": { "type": "string" }
        }
      },
      "AssuranceGate": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
