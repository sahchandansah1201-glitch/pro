{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro Self-hosted Clinical Workspace Contracts",
    "version": "5H-clinical-workspace-contracts"
  },
  "servers": [{ "url": "/" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "ClinicalAssessment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "ready", "signed"] },
          "riskLevel": { "type": ["string", "null"], "enum": ["low", "moderate", "high", "urgent", null] },
          "abcdTotal": { "type": ["number", "null"] },
          "sevenPointTotal": { "type": ["integer", "null"] },
          "summary": { "type": ["string", "null"] },
          "recommendation": { "type": ["string", "null"] }
        }
      },
      "ClinicalConclusion": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "ready", "signed"] },
          "summary": { "type": ["string", "null"] },
          "nextStep": { "type": ["string", "null"] },
          "followUpAt": { "type": ["string", "null"] }
        }
      },
      "VisitReport": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string" },
          "physicianText": { "type": ["string", "null"] },
          "patientSafeText": { "type": ["string", "null"] }
        }
      },
      "LesionComparisonDecisionDraft": {
        "type": "object",
        "description": "Metadata-only doctor draft for a selected lesion image-pair decision. No patient delivery or protected file fields.",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "lesionId": { "type": "string" },
          "pairKey": { "type": "string" },
          "imageIds": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" } },
          "action": { "type": "string", "enum": ["retake", "excluded", "report_limit"] },
          "comparability": { "type": "string", "enum": ["comparable", "not_comparable"] },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false },
          "createdAt": { "type": ["string", "null"] },
          "updatedAt": { "type": ["string", "null"] }
        }
      },
      "LesionLongitudinalHistory": {
        "type": "object",
        "description": "Production-safe doctor-side longitudinal lesion ledger assembled from visits and clinical asset metadata. No protected image bytes, storage paths, signed URLs, patient delivery, or clinical conclusion is exposed.",
        "properties": {
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": "string" },
          "lesionId": { "type": "string" },
          "label": { "type": ["string", "null"] },
          "bodyZone": { "type": ["string", "null"] },
          "bodySurface": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "summary": {
            "type": "object",
            "properties": {
              "visitCount": { "type": "integer", "minimum": 0 },
              "imageCount": { "type": "integer", "minimum": 0 },
              "candidatePairCount": { "type": "integer", "minimum": 0 },
              "comparablePairCount": { "type": "integer", "minimum": 0 },
              "warningPairCount": { "type": "integer", "minimum": 0 },
              "blockedPairCount": { "type": "integer", "minimum": 0 },
              "assessmentCount": { "type": "integer", "minimum": 0 }
            }
          },
          "visits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "visitId": { "type": "string" },
                "startedAt": { "type": ["string", "null"] },
                "signedAt": { "type": ["string", "null"] },
                "status": { "type": "string" },
                "imageCount": { "type": "integer", "minimum": 0 },
                "dermoscopyCount": { "type": "integer", "minimum": 0 },
                "overviewCount": { "type": "integer", "minimum": 0 },
                "assessmentCount": { "type": "integer", "minimum": 0 },
                "capturedAtFirst": { "type": ["string", "null"] },
                "capturedAtLast": { "type": ["string", "null"] }
              }
            }
          },
          "candidatePairs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "previousVisitId": { "type": "string" },
                "currentVisitId": { "type": "string" },
                "previousImageId": { "type": "string" },
                "currentImageId": { "type": "string" },
                "kind": { "type": "string" },
                "status": { "type": "string", "enum": ["ready", "warning", "blocked"] },
                "reasons": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "protectedFieldsExposed": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "rawImageBytesExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false },
              "clinicalConclusionGenerated": { "type": "boolean", "const": false }
            }
          }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/visits/{visitId}/assessment": {
      "get": {
        "summary": "Read the production clinical assessment for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Assessment or null" } }
      },
      "patch": {
        "summary": "Create or update the production clinical assessment for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClinicalAssessment" } } }
        },
        "responses": { "200": { "description": "Saved assessment" } }
      }
    },
    "/api/v1/visits/{visitId}/conclusion": {
      "get": {
        "summary": "Read the production clinical conclusion for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Conclusion or null" } }
      },
      "patch": {
        "summary": "Create or update the production clinical conclusion for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClinicalConclusion" } } }
        },
        "responses": { "200": { "description": "Saved conclusion" } }
      }
    },
    "/api/v1/visits/{visitId}/report": {
      "get": {
        "summary": "Read the production visit report",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Report or null" } }
      },
      "patch": {
        "summary": "Create or update the production visit report",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VisitReport" } } }
        },
        "responses": { "200": { "description": "Saved report" } }
      }
    },
    "/api/v1/visits/{visitId}/lesion-comparison-draft": {
      "patch": {
        "summary": "Persist a metadata-only doctor draft for a selected lesion image-pair comparison decision",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LesionComparisonDecisionDraft" } } }
        },
        "responses": { "200": { "description": "Saved metadata-only comparison draft" } }
      }
    },
    "/api/v1/patients/{patientId}/lesions/{lesionId}/longitudinal-history": {
      "get": {
        "summary": "Read a doctor-side metadata-only longitudinal ledger for one lesion across visits",
        "parameters": [
          { "name": "patientId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "lesionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Metadata-only longitudinal lesion history" } }
      }
    }
  }
}
