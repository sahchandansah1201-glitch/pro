{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro Self-hosted Clinical Workspace Contracts",
    "version": "5H-clinical-workspace-contracts"
  },
  "servers": [{ "url": "/" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "ClinicalAssessment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "ready", "signed"] },
          "riskLevel": { "type": ["string", "null"], "enum": ["low", "moderate", "high", "urgent", null] },
          "abcdTotal": { "type": ["number", "null"] },
          "sevenPointTotal": { "type": ["integer", "null"] },
          "summary": { "type": ["string", "null"] },
          "recommendation": { "type": ["string", "null"] }
        }
      },
      "ClinicalConclusion": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string", "enum": ["draft", "ready", "signed"] },
          "summary": { "type": ["string", "null"] },
          "nextStep": { "type": ["string", "null"] },
          "followUpAt": { "type": ["string", "null"] }
        }
      },
      "VisitReport": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "status": { "type": "string" },
          "physicianText": { "type": ["string", "null"] },
          "patientSafeText": { "type": ["string", "null"] }
        }
      },
      "LesionComparisonDecisionDraft": {
        "type": "object",
        "description": "Metadata-only doctor draft for a selected lesion image-pair decision. No patient delivery or protected file fields.",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "lesionId": { "type": "string" },
          "pairKey": { "type": "string" },
          "imageIds": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" } },
          "action": { "type": "string", "enum": ["retake", "excluded", "report_limit"] },
          "comparability": { "type": "string", "enum": ["comparable", "not_comparable"] },
          "reasons": { "type": "array", "items": { "type": "string" } },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false },
          "createdAt": { "type": ["string", "null"] },
          "updatedAt": { "type": ["string", "null"] }
        }
      },
      "AssetCaptureMetadata": {
        "type": "object",
        "description": "Production capture metadata for one clinical asset. No image bytes, storage paths, signed URLs, QR/session/credential material, or patient delivery.",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "assetId": { "type": "string" },
          "captureSource": { "type": "string", "enum": ["phone", "device_bridge", "file_import", "camera", "local_transfer", "unknown"] },
          "deviceId": { "type": ["string", "null"] },
          "frame": {
            "type": "object",
            "properties": {
              "width": { "type": ["integer", "null"], "minimum": 1 },
              "height": { "type": ["integer", "null"], "minimum": 1 }
            }
          },
          "quality": {
            "type": "object",
            "properties": {
              "score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
              "issues": { "type": "array", "items": { "type": "string" } }
            }
          },
          "calibration": {
            "type": "object",
            "properties": {
              "scaleMarkerDetected": { "type": "boolean" },
              "millimetersAvailable": { "type": "boolean" }
            }
          },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false }
        }
      },
      "LesionCaptureMetadata": {
        "type": "object",
        "description": "Doctor-side production capture metadata ledger for one lesion. Metadata-only and no clinical conclusion.",
        "properties": {
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": "string" },
          "lesionId": { "type": "string" },
          "summary": {
            "type": "object",
            "properties": {
              "assetCount": { "type": "integer", "minimum": 0 },
              "metadataCount": { "type": "integer", "minimum": 0 },
              "missingMetadataCount": { "type": "integer", "minimum": 0 },
              "readyForTechnicalCompareCount": { "type": "integer", "minimum": 0 },
              "scaleReadyCount": { "type": "integer", "minimum": 0 }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "assetId": { "type": "string" },
                "visitId": { "type": ["string", "null"] },
                "kind": { "type": "string" },
                "contentType": { "type": ["string", "null"] },
                "capturedAt": { "type": ["string", "null"] },
                "captureSource": { "type": "string" },
                "deviceId": { "type": ["string", "null"] },
                "deviceProfile": { "type": ["string", "null"] },
                "frame": { "type": "object" },
                "quality": { "type": "object" },
                "calibration": { "type": "object" },
                "technicalStatus": { "type": "string", "enum": ["ready", "warning", "missing"] },
                "technicalReasons": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "protectedFieldsExposed": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "rawImageBytesExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false },
              "clinicalConclusionGenerated": { "type": "boolean", "const": false }
            }
          }
        }
      },
      "LesionComparisonViewerQaDraft": {
        "type": "object",
        "description": "Metadata-only doctor viewer QA draft for technical markers and calibration limits. Patient delivery and medical measurements are disabled.",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "lesionId": { "type": "string" },
          "pairKey": { "type": "string" },
          "imageIds": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" } },
          "technicalMarkers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "target": { "type": "string", "enum": ["A", "B"] },
                "xPercent": { "type": "number", "minimum": 0, "maximum": 100 },
                "yPercent": { "type": "number", "minimum": 0, "maximum": 100 }
              }
            }
          },
          "calibrationStatus": { "type": "string", "enum": ["ready", "not_ready", "limited"] },
          "calibrationReasons": { "type": "array", "items": { "type": "string" } },
          "captureMetadataStatus": { "type": "string", "enum": ["ready", "needs_review", "missing"] },
          "review": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["unreviewed", "technical_ready", "needs_recapture", "not_suitable_for_comparison"]
              },
              "reasons": { "type": "array", "items": { "type": "string" } },
              "reviewedAt": { "type": ["string", "null"] },
              "reviewedByUserId": { "type": ["string", "null"] }
            }
          },
          "reviewerWorkflow": {
            "type": "object",
            "description": "Batch BH calibrated reviewer workflow gate. Metadata only; no patient delivery, medical measurement, or clinical conclusion.",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["technical_gate_blocked", "ready_for_reviewer", "reviewer_accepted", "reviewer_rejected"]
              },
              "reasons": { "type": "array", "items": { "type": "string" } },
              "reviewedAt": { "type": ["string", "null"] },
              "reviewedByUserId": { "type": ["string", "null"] },
              "gate": {
                "type": "object",
                "properties": {
                  "technicalReviewReady": { "type": "boolean" },
                  "calibrationReady": { "type": "boolean" },
                  "captureMetadataReady": { "type": "boolean" },
                  "markerGateReady": { "type": "boolean" },
                  "medicalMeasurementAllowed": { "type": "boolean", "const": false },
                  "patientDeliveryAllowed": { "type": "boolean", "const": false },
                  "clinicalConclusionGenerated": { "type": "boolean", "const": false }
                }
              }
            }
          },
          "medicalMeasurementAllowed": { "type": "boolean", "const": false },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false }
        }
      },
      "LesionComparisonViewerQaReview": {
        "type": "object",
        "description": "Metadata-only doctor technical review over an existing viewer QA draft. Patient delivery, medical measurements and clinical dynamic conclusions are disabled.",
        "properties": {
          "lesionId": { "type": "string" },
          "pairKey": { "type": "string" },
          "imageIds": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" } },
          "reviewStatus": {
            "type": "string",
            "enum": ["technical_ready", "needs_recapture", "not_suitable_for_comparison"]
          },
          "reviewReasons": { "type": "array", "items": { "type": "string" } },
          "medicalMeasurementAllowed": { "type": "boolean", "const": false },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false }
        },
        "required": ["lesionId", "pairKey", "imageIds", "reviewStatus"]
      },
      "LesionComparisonViewerQaReviewerWorkflow": {
        "type": "object",
        "description": "Batch BH metadata-only calibrated reviewer workflow over an existing technical-ready viewer QA draft. Backend gates require technical_ready review, ready calibration, ready capture metadata, and two technical markers.",
        "properties": {
          "lesionId": { "type": "string" },
          "pairKey": { "type": "string" },
          "imageIds": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "string" } },
          "workflowStatus": {
            "type": "string",
            "enum": ["ready_for_reviewer", "reviewer_accepted", "reviewer_rejected"]
          },
          "workflowReasons": { "type": "array", "items": { "type": "string" } },
          "medicalMeasurementAllowed": { "type": "boolean", "const": false },
          "patientDeliveryAllowed": { "type": "boolean", "const": false },
          "protectedFieldsExposed": { "type": "boolean", "const": false }
        },
        "required": ["lesionId", "pairKey", "imageIds", "workflowStatus"]
      },
      "LesionComparisonViewerQaReviewQueue": {
        "type": "object",
        "description": "Visit-scoped doctor queue for metadata-only viewer QA review decisions. Pair keys, image IDs, protected image fields, patient delivery, medical measurements, and clinical dynamic conclusions are not exposed.",
        "properties": {
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitId": { "type": "string" },
          "filters": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["actionable", "all", "unreviewed", "technical_ready", "needs_recapture", "not_suitable_for_comparison"]
              },
              "limit": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "total": { "type": "integer", "minimum": 0 },
              "unreviewed": { "type": "integer", "minimum": 0 },
              "technicalReady": { "type": "integer", "minimum": 0 },
              "needsRecapture": { "type": "integer", "minimum": 0 },
              "notSuitableForComparison": { "type": "integer", "minimum": 0 },
              "actionable": { "type": "integer", "minimum": 0 }
            }
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "queueNumber": { "type": "integer", "minimum": 0 },
                "lesionId": { "type": "string" },
                "lesionLabel": { "type": "string" },
                "bodyZone": { "type": ["string", "null"] },
                "bodySurface": { "type": ["string", "null"] },
                "review": { "type": "object" },
                "calibrationStatus": { "type": "string" },
                "calibrationReasons": { "type": "array", "items": { "type": "string" } },
                "captureMetadataStatus": { "type": "string" },
                "technicalMarkerCount": { "type": "integer", "minimum": 0 },
                "updatedAt": { "type": ["string", "null"] },
                "nextAction": {
                  "type": "string",
                  "enum": ["review_pair", "request_recapture", "exclude_from_dynamic_review", "continue_review"]
                }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "medicalMeasurementAllowed": { "type": "boolean", "const": false },
              "protectedFieldsExposed": { "type": "boolean", "const": false },
              "pairKeysExposed": { "type": "boolean", "const": false },
              "imageIdsExposed": { "type": "boolean", "const": false },
              "clinicalConclusionGenerated": { "type": "boolean", "const": false }
            }
          }
        }
      },
      "LesionLongitudinalQa": {
        "type": "object",
        "description": "Metadata-only longitudinal QA readiness gate for a lesion timeline. It exposes aggregate technical readiness only: no pair keys, image IDs, protected image fields, patient delivery, medical measurements, or clinical dynamic conclusions.",
        "properties": {
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "lesionId": { "type": "string" },
          "label": { "type": ["string", "null"] },
          "readiness": {
            "type": "object",
            "properties": {
              "status": { "type": "string", "enum": ["blocked", "needs_review", "technical_ready"] },
              "visitCount": { "type": "integer", "minimum": 0 },
              "imageCount": { "type": "integer", "minimum": 0 },
              "candidatePairCount": { "type": "integer", "minimum": 0 },
              "reviewedPairCount": { "type": "integer", "minimum": 0 },
              "technicalReadyPairCount": { "type": "integer", "minimum": 0 },
              "needsRecaptureCount": { "type": "integer", "minimum": 0 },
              "notSuitableForComparisonCount": { "type": "integer", "minimum": 0 },
              "unreviewedPairCount": { "type": "integer", "minimum": 0 },
              "missingCaptureMetadataCount": { "type": "integer", "minimum": 0 },
              "calibrationBlockedCount": { "type": "integer", "minimum": 0 },
              "markerMissingCount": { "type": "integer", "minimum": 0 },
              "technicalRolloutReady": { "type": "boolean" },
              "dynamicConclusionAllowed": { "type": "boolean", "const": false }
            }
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "no_candidate_pairs",
                    "recapture_required",
                    "not_suitable_for_comparison",
                    "unreviewed_pairs",
                    "missing_capture_metadata",
                    "calibration_not_ready",
                    "technical_markers_missing"
                  ]
                },
                "label": { "type": "string" },
                "count": { "type": "integer", "minimum": 1 },
                "nextAction": {
                  "type": "string",
                  "enum": [
                    "review_queue",
                    "request_recapture",
                    "exclude_from_dynamic_review",
                    "complete_capture_metadata",
                    "complete_calibration",
                    "place_markers",
                    "continue_review"
                  ]
                }
              }
            }
          },
          "nextActions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "review_queue",
                "request_recapture",
                "exclude_from_dynamic_review",
                "complete_capture_metadata",
                "complete_calibration",
                "place_markers",
                "continue_review"
              ]
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "medicalMeasurementAllowed": { "type": "boolean", "const": false },
              "protectedFieldsExposed": { "type": "boolean", "const": false },
              "pairKeysExposed": { "type": "boolean", "const": false },
              "imageIdsExposed": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "rawImageBytesExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false },
              "clinicalConclusionGenerated": { "type": "boolean", "const": false }
            }
          }
        }
      },
      "LesionLongitudinalHistory": {
        "type": "object",
        "description": "Production-safe doctor-side longitudinal lesion ledger assembled from visits and clinical asset metadata. No protected image bytes, storage paths, signed URLs, patient delivery, or clinical conclusion is exposed.",
        "properties": {
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": "string" },
          "lesionId": { "type": "string" },
          "label": { "type": ["string", "null"] },
          "bodyZone": { "type": ["string", "null"] },
          "bodySurface": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "summary": {
            "type": "object",
            "properties": {
              "visitCount": { "type": "integer", "minimum": 0 },
              "imageCount": { "type": "integer", "minimum": 0 },
              "candidatePairCount": { "type": "integer", "minimum": 0 },
              "comparablePairCount": { "type": "integer", "minimum": 0 },
              "warningPairCount": { "type": "integer", "minimum": 0 },
              "blockedPairCount": { "type": "integer", "minimum": 0 },
              "assessmentCount": { "type": "integer", "minimum": 0 }
            }
          },
          "visits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "visitId": { "type": "string" },
                "startedAt": { "type": ["string", "null"] },
                "signedAt": { "type": ["string", "null"] },
                "status": { "type": "string" },
                "imageCount": { "type": "integer", "minimum": 0 },
                "dermoscopyCount": { "type": "integer", "minimum": 0 },
                "overviewCount": { "type": "integer", "minimum": 0 },
                "assessmentCount": { "type": "integer", "minimum": 0 },
                "capturedAtFirst": { "type": ["string", "null"] },
                "capturedAtLast": { "type": ["string", "null"] }
              }
            }
          },
          "candidatePairs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "previousVisitId": { "type": "string" },
                "currentVisitId": { "type": "string" },
                "previousImageId": { "type": "string" },
                "currentImageId": { "type": "string" },
                "kind": { "type": "string" },
                "status": { "type": "string", "enum": ["ready", "warning", "blocked"] },
                "reasons": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "protectedFieldsExposed": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "rawImageBytesExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false },
              "clinicalConclusionGenerated": { "type": "boolean", "const": false }
            }
          }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/visits/{visitId}/assessment": {
      "get": {
        "summary": "Read the production clinical assessment for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Assessment or null" } }
      },
      "patch": {
        "summary": "Create or update the production clinical assessment for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClinicalAssessment" } } }
        },
        "responses": { "200": { "description": "Saved assessment" } }
      }
    },
    "/api/v1/visits/{visitId}/conclusion": {
      "get": {
        "summary": "Read the production clinical conclusion for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Conclusion or null" } }
      },
      "patch": {
        "summary": "Create or update the production clinical conclusion for a visit",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClinicalConclusion" } } }
        },
        "responses": { "200": { "description": "Saved conclusion" } }
      }
    },
    "/api/v1/visits/{visitId}/report": {
      "get": {
        "summary": "Read the production visit report",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Report or null" } }
      },
      "patch": {
        "summary": "Create or update the production visit report",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VisitReport" } } }
        },
        "responses": { "200": { "description": "Saved report" } }
      }
    },
    "/api/v1/visits/{visitId}/lesion-comparison-draft": {
      "patch": {
        "summary": "Persist a metadata-only doctor draft for a selected lesion image-pair comparison decision",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LesionComparisonDecisionDraft" } } }
        },
        "responses": { "200": { "description": "Saved metadata-only comparison draft" } }
      }
    },
    "/api/v1/visits/{visitId}/lesion-comparison-viewer-qa": {
      "patch": {
        "summary": "Persist metadata-only doctor viewer QA for technical markers and calibration limits",
        "description": "Doctor-side metadata only. This never enables patient delivery, medical measurement, signed URLs, storage paths, QR/session/credential material, or clinical dynamic conclusions.",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LesionComparisonViewerQaDraft" } } }
        },
        "responses": { "200": { "description": "Saved metadata-only viewer QA draft" } }
      }
    },
    "/api/v1/visits/{visitId}/lesion-comparison-viewer-qa/review": {
      "patch": {
        "summary": "Persist a metadata-only doctor technical review for an existing viewer QA draft",
        "description": "Doctor-side technical review only. This never enables patient delivery, medical measurement, signed URLs, storage paths, QR/session/credential material, or clinical dynamic conclusions.",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LesionComparisonViewerQaReview" } } }
        },
        "responses": { "200": { "description": "Saved metadata-only viewer QA review" } }
      }
    },
    "/api/v1/visits/{visitId}/lesion-comparison-viewer-qa/reviewer-workflow": {
      "patch": {
        "summary": "Persist Batch BH calibrated reviewer workflow metadata for an existing viewer QA draft",
        "description": "Backend gates require technical_ready review, ready calibration, ready capture metadata, and two technical markers. This never enables patient delivery, medical measurement, signed URLs, storage paths, QR/session/credential material, or clinical dynamic conclusions.",
        "parameters": [{ "name": "visitId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
