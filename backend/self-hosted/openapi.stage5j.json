{
  "openapi": "3.1.0",
  "info": {
    "title": "Dermatologist Pro Self-hosted API · Stage 5J",
    "version": "5J-visit-schedule-contracts"
  },
  "servers": [{ "url": "/" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/visits": {
      "get": {
        "summary": "List role-scoped visit schedule from PostgreSQL",
        "operationId": "listVisitSchedule",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "in_progress", "signed", "cancelled"] } },
          { "name": "dateFrom", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "dateTo", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "search", "in": "query", "schema": { "type": "string", "maxLength": 120 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 200 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "minimum": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Visit schedule list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "items", "count"],
                  "properties": {
                    "stage": { "const": "5J" },
                    "source": { "const": "postgres" },
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/VisitScheduleItem" }
                    },
                    "count": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" },
                    "filters": { "type": "object" },
                    "generatedAt": { "type": "string", "format": "date-time" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Authentication required" },
          "403": { "description": "Role cannot read visits" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "VisitScheduleItem": {
        "type": "object",
        "required": ["id", "status", "patient", "clinic"],
        "properties": {
          "id": { "type": "string" },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "doctorUserId": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "startedAt": { "type": ["string", "null"], "format": "date-time" },
          "signedAt": { "type": ["string", "null"], "format": "date-time" },
          "chiefComplaint": { "type": ["string", "null"] },
          "patient": {
            "type": "object",
            "properties": {
              "id": { "type": ["string", "null"] },
              "fullName": { "type": ["string", "null"] },
              "code": { "type": ["string", "null"] }
            }
          },
          "clinic": {
            "type": "object",
            "properties": {
              "id": { "type": ["string", "null"] },
              "slug": { "type": ["string", "null"] },
              "name": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
