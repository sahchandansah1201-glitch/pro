{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro self-hosted external intake import API",
    "version": "5Q-external-intake-import-contracts",
    "description": "Stage 5Q production contracts for inbound CRM/ad booking imports and locally cached available slots. The backend stores sanitized metadata in PostgreSQL and performs no outbound third-party runtime calls."
  },
  "paths": {
    "/api/v1/integrations/booking-imports": {
      "get": {
        "summary": "List recent external booking import batches",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "sourceSystem", "in": "query", "schema": { "type": "string", "enum": ["all", "clinic_crm", "ads", "site", "manual", "other"] } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "minimum": 0 } }
        ],
        "responses": {
          "200": {
            "description": "Import batch history",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImportBatchListResponse" } } }
          },
          "401": { "description": "Authentication required" },
          "403": { "description": "Role is not allowed to inspect imports" }
        }
      },
      "post": {
        "summary": "Import sanitized booking requests and available slots",
        "description": "Accepts inbound data from operator-owned CRM/ad adapters. Raw CRM payloads, tokens, URLs, and managed-service IDs must be stripped before this endpoint is called.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImportRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Import batch recorded",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImportBatchResponse" } } }
          },
          "401": { "description": "Authentication required" },
          "403": { "description": "Role or clinic scope is not allowed" },
          "422": { "description": "Payload failed validation" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "ImportRequest": {
        "type": "object",
        "required": ["sourceSystem", "items"],
        "properties": {
          "clinicId": { "type": "string", "format": "uuid" },
          "sourceSystem": { "type": "string", "enum": ["clinic_crm", "ads", "site", "manual", "other"] },
          "sourceReference": { "type": "string", "maxLength": 120 },
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": { "$ref": "#/components/schemas/ImportItem" }
          }
        }
      },
      "ImportItem": {
        "type": "object",
        "required": ["kind", "externalId"],
        "oneOf": [
          { "$ref": "#/components/schemas/BookingRequestImportItem" },
          { "$ref": "#/components/schemas/AvailableSlotImportItem" }
        ]
      },
      "BookingRequestImportItem": {
        "type": "object",
        "required": ["kind", "externalId", "patientCode", "preferredFrom"],
        "properties": {
          "kind": { "type": "string", "enum": ["booking_request"] },
          "externalId": { "type": "string" },
          "patientCode": { "type": "string" },
          "preferredFrom": { "type": "string", "format": "date-time" },
          "preferredTo": { "type": "string", "format": "date-time" },
          "reason": { "type": "string", "maxLength": 500 }
        }
      },
      "AvailableSlotImportItem": {
        "type": "object",
        "required": ["kind", "externalId", "startedAt"],
        "properties": {
          "kind": { "type": "string", "enum": ["available_slot"] },
          "externalId": { "type": "string" },
          "doctorUserId": { "type": "string", "format": "uuid" },
          "startedAt": { "type": "string", "format": "date-time" },
          "durationMinutes": { "type": "integer", "minimum": 5, "maximum": 720 }
        }
      },
      "ImportBatch": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "clinicId": { "type": "string" },
          "sourceSystem": { "type": "string" },
          "sourceReference": { "type": "string", "nullable": true },
          "status": { "type": "string" },
          "itemCount": { "type": "integer" },
          "acceptedBookingCount": { "type": "integer" },
          "acceptedSlotCount": { "type": "integer" },
          "rejectedCount": { "type": "integer" },
          "summary": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time", "nullable": true }
        }
      },
      "ImportBatchResponse": {
        "type": "object",
        "properties": {
          "stage": { "type": "string", "enum": ["5Q"] },
          "source": { "type": "string", "enum": ["postgres"] },
          "item": { "$ref": "#/components/schemas/ImportBatch" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "correlationId": { "type": "string" }
        }
      },
      "ImportBatchListResponse": {
        "type": "object",
        "properties": {
          "stage": { "type": "string", "enum": ["5Q"] },
          "source": { "type": "string", "enum": ["postgres"] },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/ImportBatch" } },
          "count": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "correlationId": { "type": "string" }
        }
      }
    }
  }
}
