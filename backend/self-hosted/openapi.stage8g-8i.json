{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro self-hosted API",
    "version": "8G-8I-clinical-reporting-completion",
    "description": "Stage 8G-8I clinical reporting completion package. Self-hosted PostgreSQL only; no managed runtime or managed database dependency."
  },
  "paths": {
    "/api/v1/visits/{visitId}/report-package": {
      "get": {
        "summary": "Read clinical report completion package",
        "description": "Returns a safe report readiness snapshot assembled from local visits, lesions, assets, assessments, conclusions, and reports. The response contains counts and booleans only; it does not expose object storage paths, signed URLs, tokens, or raw patient data.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Clinical report package readiness",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/ClinicalReportPackage" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/report package not found" },
          "422": { "description": "Invalid visit id" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release": {
      "post": {
        "summary": "Prepare patient photo/protocol release ledger",
        "description": "Persists metadata-only release readiness for doctor-selected patient photo/protocol access. It does not deliver files, issue signed URLs, expose storage paths, or create patient access tokens.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expiresAt": { "type": ["string", "null"], "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Metadata-only release ledger",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolRelease" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/release not found" },
          "422": { "description": "Invalid payload" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release/revoke": {
      "post": {
        "summary": "Revoke patient photo/protocol release ledger",
        "description": "Revokes metadata-only patient photo/protocol release state. It does not revoke external links because this contract never issues links or tokens.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": { "type": "string", "maxLength": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revoked metadata-only release ledger",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolRelease" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/release not found" },
          "422": { "description": "Invalid payload" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release/policy": {
      "post": {
        "summary": "Review patient photo protocol release policy",
        "description": "Doctor-only policy governance update for patient photo delivery gates. Updates metadata flags and optional expiry without exposing raw file artifacts.",
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expiresAt": { "type": ["string", "null"], "format": "date-time" },
                  "patientFileProxyEnabled": { "type": "boolean" },
                  "patientCopyApproved": { "type": "boolean" },
                  "retentionPolicyApproved": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Policy review saved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolRelease" },
                    "generatedAt": { "type": "string", "format": "date-time" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Authentication required" },
          "403": { "description": "Doctor role is required" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release/audit": {
      "get": {
        "summary": "Read staff/admin photo protocol release audit",
        "description": "Returns a safe immutable audit review for patient photo/protocol release operations. It exposes event labels, counts, timestamps and reason-present flags only; it does not expose raw audit payloads, actor identifiers, internal request identifiers, revoke reason text, tokens, storage paths, signed links, object storage identifiers, or physician-only text.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Staff-safe immutable audit review",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolReleaseAudit" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Release audit not found" },
          "422": { "description": "Invalid visit id" }
        }
      }
    },
    "/api/v1/patient-photo-protocol-release/governance": {
      "get": {
        "summary": "Read aggregate photo protocol release governance",
        "description": "Returns aggregate clinic-scope governance for patient photo/protocol release policies and access windows. The response is metadata-only and does not expose patients, photos, raw identifiers, tokens, storage paths, signed links, or doctor-only text.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Aggregate metadata-only release governance",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolReleaseGovernance" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" }
        }
      }
    },
    "/api/v1/patient-photo-protocol-release/governance/revoke-expired": {
      "post": {
        "summary": "Execute aggregate revoke for expired access windows",
        "description": "Production-safe lifecycle operation that revokes expired patient photo/protocol release rows inside the caller's clinic scope. The response is aggregate-only and never exposes patient rows, raw identifiers, revoke reason text, credentials, QR tokens, session identifiers, file paths, or signed links.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["confirm"],
                "properties": {
                  "confirm": { "type": "boolean", "enum": [true] },
                  "limit": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aggregate operation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolGovernanceOperationResult" },
                    "generatedAt": { "type": "string", "format": "date-time" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "422": { "description": "Confirm or limit validation failed" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ClinicalReportPackage": {
        "type": "object",
        "required": [
          "visitId",
          "assessment",
          "conclusion",
          "report",
          "counts",
          "readiness",
          "patientPhotoProtocol",
          "productBoundary"
        ],
        "properties": {
          "visitId": { "type": "string" },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitStatus": { "type": "string" },
          "assessment": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "riskLevel": { "type": ["string", "null"] },
              "abcdTotal": { "type": ["number", "null"] },
              "sevenPointTotal": { "type": ["number", "null"] },
              "summaryPresent": { "type": "boolean" },
              "recommendationPresent": { "type": "boolean" }
            }
          },
          "conclusion": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "summaryPresent": { "type": "boolean" },
              "nextStepPresent": { "type": "boolean" },
              "followUpAt": { "type": ["string", "null"] }
            }
          },
          "report": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "physicianTextPresent": { "type": "boolean" },
              "patientSafeTextPresent": { "type": "boolean" },
              "signedAt": { "type": ["string", "null"] }
            }
          },
          "counts": {
            "type": "object",
            "properties": {
              "lesions": { "type": "integer" },
              "assets": { "type": "integer" }
            }
          },
          "readiness": {
            "type": "object",
            "properties": {
              "ready": { "type": "boolean" },
              "status": { "type": "string", "enum": ["ready", "blocked"] },
              "completionPercent": { "type": "integer" },
              "missing": {
                "type": "array",
                "items": { "type": "string" }
              },
              "exportAllowed": { "type": "boolean" },
              "patientDeliveryAllowed": { "type": "boolean" }
            }
          },
          "patientPhotoProtocol": {
            "type": "object",
            "description": "Safe backend contract for doctor-selected patient photo/protocol metadata. It never exposes raw files, object storage paths, signed URLs, tokens, or physician-only text.",
            "properties": {
              "brainstormTask": { "type": "string", "enum": ["SD-MF-046"] },
              "status": {
                "type": "string",
                "enum": ["metadata_ready_backend_blocked", "blocked"]
              },
              "readyForBackendContract": { "type": "boolean" },
              "selectedPhotoCount": { "type": "integer" },
              "counts": {
                "type": "object",
                "properties": {
                  "selectedPhotos": { "type": "integer" },
                  "overviewPhotos": { "type": "integer" },
                  "dermoscopyPhotos": { "type": "integer" },
                  "reportAttachments": { "type": "integer" }
                }
              },
              "missing": {
                "type": "array",
                "items": { "type": "string" }
              },
              "deliveryBoundary": {
                "type": "object",
                "properties": {
                  "patientDeliveryAllowed": { "type": "boolean" },
                  "rawFilesExposed": { "type": "boolean" },
                  "signedUrlsIssued": { "type": "boolean" },
                  "storagePathsExposed": { "type": "boolean" },
                  "tokensExposed": { "type": "boolean" },
                  "physicianTextExposed": { "type": "boolean" },
                  "fileProxyReady": { "type": "boolean" },
                  "requiresSelfHostedFileProxy": { "type": "boolean" },
                  "requiresReleaseAudit": { "type": "boolean" },
                  "requiresRevoke": { "type": "boolean" },
                  "requiresIdentityCheck": { "type": "boolean" },
                  "requiresRetentionPolicy": { "type": "boolean" },
                  "requiresApprovedPatientCopy": { "type": "boolean" }
                }
              },
              "policy": {
                "type": "object",
                "properties": {
                  "releasePrepared": { "type": "boolean" },
                  "patientFileProxyEnabled": { "type": "boolean" },
                  "patientCopyApproved": { "type": "boolean" },
                  "retentionPolicyApproved": { "type": "boolean" },
                  "expiresAt": { "type": ["string", "null"], "format": "date-time" }
                }
              }
            }
          },
          "productBoundary": {
            "type": "object",
            "properties": {
              "managedRuntimeDependency": { "type": "string", "enum": ["none"] },
              "managedDatabaseDependency": { "type": "string", "enum": ["none"] },
              "externalRuntimeCalls": { "type": "boolean" },
              "rawPatientDataInReport": { "type": "boolean" }
            }
          }
        }
      },
      "PatientPhotoProtocolRelease": {
        "type": "object",
        "description": "Metadata-only release/revoke ledger. It never exposes raw files, storage paths, signed URLs, access tokens, object storage identifiers, or physician-only text.",
        "properties": {
          "id": { "type": "string" },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitId": { "type": ["string", "null"] },
          "reportId": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["blocked", "prepared", "revoked"] },
          "selectedPhotoCount": { "type": "integer" },
          "counts": {
            "type": "object",
            "properties": {
              "selectedPhotos": { "type": "integer" },
              "overviewPhotos": { "type": "integer" },
              "dermoscopyPhotos": { "type": "integer" },
              "reportAttachments": { "type": "integer" }
            }
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preparedAt": { "type": ["string", "null"] },
          "revokedAt": { "type": ["string", "null"] },
          "revokeReason": { "type": ["string", "null"] },
          "expiresAt": { "type": ["string", "null"] },
          "deliveryBoundary": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean" },
              "rawFilesExposed": { "type": "boolean" },
              "signedUrlsIssued": { "type": "boolean" },
              "storagePathsExposed": { "type": "boolean" },
              "tokensExposed": { "type": "boolean" },
              "physicianTextExposed": { "type": "boolean" },
              "fileProxyReady": { "type": "boolean" },
              "requiresSelfHostedFileProxy": { "type": "boolean" },
              "requiresReleaseAudit": { "type": "boolean" },
              "requiresRevoke": { "type": "boolean" },
              "requiresIdentityCheck": { "type": "boolean" },
              "requiresRetentionPolicy": { "type": "boolean" },
              "requiresApprovedPatientCopy": { "type": "boolean" }
            }
          },
          "policy": {
            "type": "object",
            "properties": {
              "patientFileProxyEnabled": { "type": "boolean" },
              "patientCopyApproved": { "type": "boolean" },
              "retentionPolicyApproved": { "type": "boolean" }
            }
          }
        }
      },
      "PatientPhotoProtocolReleaseGovernance": {
        "type": "object",
        "description": "Aggregate staff/admin governance for release policies and patient access windows. Queue rows are metadata-only and omit patient names, raw identifiers, files, storage paths, links, tokens, and doctor-only text.",
        "properties": {
          "summary": {
            "type": "object",
            "properties": {
              "releasesTotal": { "type": "integer" },
              "prepared": { "type": "integer" },
              "blocked": { "type": "integer" },
              "revoked": { "type": "integer" },
              "retentionMissing": { "type": "integer" },
              "patientCopyMissing": { "type": "integer" },
              "fileProxyMissing": { "type": "integer" },
              "expiryMissing": { "type": "integer" },
              "activeAccessWindows": { "type": "integer" },
              "expiringIn24h": { "type": "integer" }
            }
          },
          "queue": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "queueNumber": { "type": "integer" },
                "status": { "type": "string", "enum": ["blocked", "prepared", "revoked"] },
                "policyStatus": {
                  "type": "string",
                  "enum": ["ready_for_access_window", "retention_required", "patient_copy_required", "file_proxy_required", "blocked", "revoked"]
                },
                "selectedPhotoCount": { "type": "integer" },
                "blockerCount": { "type": "integer" },
                "expiresAt": { "type": ["string", "null"], "format": "date-time" },
                "updatedAt": { "type": ["string", "null"], "format": "date-time" },
                "patientFileProxyEnabled": { "type": "boolean" },
                "patientCopyApproved": { "type": "boolean" },
                "retentionPolicyApproved": { "type": "boolean" },
                "attention": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "operations": {
            "type": "object",
            "description": "Aggregate-only operations readiness for retention review, revoke review and session lifecycle. Does not expose patient rows, raw IDs, QR tokens, temporary credentials, storage paths, signed URLs or doctor-only text.",
            "properties": {
              "retention": {
                "type": "object",
                "properties": {
                  "reviewDue": { "type": "integer" },
                  "ready": { "type": "integer" },
                  "blocked": { "type": "integer" },
                  "requiresClinicSignoff": { "type": "boolean" },
                  "nextAction": { "type": "string", "enum": ["review_retention_policy"] }
                }
              },
              "revokeReadiness": {
                "type": "object",
                "properties": {
                  "activeWindows": { "type": "integer" },
                  "expiringIn24h": { "type": "integer" },
                  "revoked": { "type": "integer" },
                  "canPrepareRevokeReview": { "type": "integer" },
                  "requiresManualReason": { "type": "boolean", "enum": [true] },
                  "revokeReasonExposed": { "type": "boolean", "enum": [false] }
                }
              },
              "sessionLifecycle": {
                "type": "object",
                "properties": {
                  "active": { "type": "integer" },
                  "expiringIn24h": { "type": "integer" },
                  "missingExpiry": { "type": "integer" },
                  "revoked": { "type": "integer" },
                  "temporaryCredentialsExposed": { "type": "boolean", "enum": [false] },
                  "qrTokensExposed": { "type": "boolean", "enum": [false] },
                  "sessionIdsExposed": { "type": "boolean", "enum": [false] }
                }
              },
              "allowedOperations": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blockedOperations": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "metadataOnly": { "type": "boolean", "enum": [true] },
              "patientNamesExposed": { "type": "boolean", "enum": [false] },
              "rawIdentifiersExposed": { "type": "boolean", "enum": [false] },
              "rawTokensExposed": { "type": "boolean", "enum": [false] },
              "rawFilesExposed": { "type": "boolean", "enum": [false] },
              "storagePathsExposed": { "type": "boolean", "enum": [false] },
              "signedUrlsIssued": { "type": "boolean", "enum": [false] },
              "doctorOnlyTextExposed": { "type": "boolean", "enum": [false] },
              "rawPolicyPayloadExposed": { "type": "boolean", "enum": [false] }
            }
          }
        }
      },
      "PatientPhotoProtocolGovernanceOperationResult": {
        "type": "object",
        "description": "Aggregate-only execution result for patient photo/protocol lifecycle operations. It does not expose patient rows, raw identifiers, revoke reason text, credentials, QR tokens, session identifiers, storage paths, signed links, or doctor-only text.",
        "properties": {
          "operation": { "type": "string", "enum": ["revoke_expired_access_windows"] },
          "status": { "type": "string", "enum": ["executed", "no_op"] },
          "affectedCount": { "type": "integer" },
          "skippedActiveCount": { "type": "integer" },
          "expiringIn24hCount": { "type": "integer" },
          "skippedMissingExpiryCount": { "type": "integer" },
          "limit": { "type": "integer" },
          "auditAction": {
            "type": "string",
            "enum": ["patient_photo_protocol.release_governance.revoke_expired"]
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "metadataOnly": { "type": "boolean", "enum": [true] },
              "patientRowsExposed": { "type": "boolean", "enum": [false] },
              "rawIdentifiersExposed": { "type": "boolean", "enum": [false] },
              "revokeReasonExposed": { "type": "boolean", "enum": [false] },
              "temporaryCredentialsExposed": { "type": "boolean", "enum": [false] },
              "qrTokensExposed": { "type": "boolean", "enum": [false] },
              "sessionIdsExposed": { "type": "boolean", "enum": [false] },
              "storagePathsExposed": { "type": "boolean", "enum": [false] },
              "signedUrlsIssued": { "type": "boolean", "enum": [false] },
              "patientDeliveryAllowed": { "type": "boolean", "enum": [false] }
            }
          }
        }
      },
      "PatientPhotoProtocolReleaseAudit": {
        "type": "object",
        "description": "Staff/admin safe audit review. The audit ledger remains append-only; raw payloads and internal identifiers remain backend-only.",
        "properties": {
          "releaseId": { "type": ["string", "null"] },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitId": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["blocked", "prepared", "revoked"] },
          "summary": {
            "type": "object",
            "properties": {
              "eventCount": { "type": "integer" },
              "preparedEvents": { "type": "integer" },
              "policyReviewEvents": { "type": "integer" },
              "revokedEvents": { "type": "integer" },
              "patientReadEvents": { "type": "integer" },
              "proxyDownloadEvents": { "type": "integer" },
              "proxyDeniedEvents": { "type": "integer" }
            }
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": ["release_prepared", "policy_reviewed", "release_revoked", "patient_read", "proxy_download", "proxy_denied", "audit_event"]
                },
                "label": { "type": "string" },
                "occurredAt": { "type": ["string", "null"] },
                "actorType": { "type": "string", "enum": ["staff", "patient"] },
                "status": { "type": ["string", "null"] },
                "selectedPhotoCount": { "type": "integer" },
                "blockerCount": { "type": "integer" },
                "patientDeliveryAllowed": { "type": "boolean" },
                "reasonPresent": { "type": "boolean" }
              }
            }
          },
          "boundaries": {
            "type": "object",
            "properties": {
              "immutableLedger": { "type": "boolean" },
              "rawPayloadExposed": { "type": "boolean", "enum": [false] },
              "revokeReasonExposed": { "type": "boolean", "enum": [false] },
              "actorIdsExposed": { "type": "boolean", "enum": [false] },
              "correlationIdsExposed": { "type": "boolean", "enum": [false] },
              "storagePathsExposed": { "type": "boolean", "enum": [false] },
              "tokensExposed": { "type": "boolean", "enum": [false] },
              "signedUrlsIssued": { "type": "boolean", "enum": [false] },
              "doctorOnlyTextExposed": { "type": "boolean", "enum": [false] }
            }
          }
        }
      }
    }
  }
}
