{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro self-hosted API",
    "version": "8G-8I-clinical-reporting-completion",
    "description": "Stage 8G-8I clinical reporting completion package. Self-hosted PostgreSQL only; no managed runtime or managed database dependency."
  },
  "paths": {
    "/api/v1/visits/{visitId}/report-package": {
      "get": {
        "summary": "Read clinical report completion package",
        "description": "Returns a safe report readiness snapshot assembled from local visits, lesions, assets, assessments, conclusions, and reports. The response contains counts and booleans only; it does not expose object storage paths, signed URLs, tokens, or raw patient data.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Clinical report package readiness",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/ClinicalReportPackage" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/report package not found" },
          "422": { "description": "Invalid visit id" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release": {
      "post": {
        "summary": "Prepare patient photo/protocol release ledger",
        "description": "Persists metadata-only release readiness for doctor-selected patient photo/protocol access. It does not deliver files, issue signed URLs, expose storage paths, or create patient access tokens.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expiresAt": { "type": ["string", "null"], "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Metadata-only release ledger",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolRelease" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/release not found" },
          "422": { "description": "Invalid payload" }
        }
      }
    },
    "/api/v1/visits/{visitId}/patient-photo-protocol-release/revoke": {
      "post": {
        "summary": "Revoke patient photo/protocol release ledger",
        "description": "Revokes metadata-only patient photo/protocol release state. It does not revoke external links because this contract never issues links or tokens.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": { "type": "string", "maxLength": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Revoked metadata-only release ledger",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item", "correlationId"],
                  "properties": {
                    "stage": { "type": "string", "enum": ["8G-8I"] },
                    "source": { "type": "string", "enum": ["postgres"] },
                    "item": { "$ref": "#/components/schemas/PatientPhotoProtocolRelease" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "Auth required" },
          "403": { "description": "Role or clinic scope denied" },
          "404": { "description": "Visit/release not found" },
          "422": { "description": "Invalid payload" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ClinicalReportPackage": {
        "type": "object",
        "required": [
          "visitId",
          "assessment",
          "conclusion",
          "report",
          "counts",
          "readiness",
          "patientPhotoProtocol",
          "productBoundary"
        ],
        "properties": {
          "visitId": { "type": "string" },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitStatus": { "type": "string" },
          "assessment": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "riskLevel": { "type": ["string", "null"] },
              "abcdTotal": { "type": ["number", "null"] },
              "sevenPointTotal": { "type": ["number", "null"] },
              "summaryPresent": { "type": "boolean" },
              "recommendationPresent": { "type": "boolean" }
            }
          },
          "conclusion": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "summaryPresent": { "type": "boolean" },
              "nextStepPresent": { "type": "boolean" },
              "followUpAt": { "type": ["string", "null"] }
            }
          },
          "report": {
            "type": "object",
            "properties": {
              "status": { "type": ["string", "null"] },
              "physicianTextPresent": { "type": "boolean" },
              "patientSafeTextPresent": { "type": "boolean" },
              "signedAt": { "type": ["string", "null"] }
            }
          },
          "counts": {
            "type": "object",
            "properties": {
              "lesions": { "type": "integer" },
              "assets": { "type": "integer" }
            }
          },
          "readiness": {
            "type": "object",
            "properties": {
              "ready": { "type": "boolean" },
              "status": { "type": "string", "enum": ["ready", "blocked"] },
              "completionPercent": { "type": "integer" },
              "missing": {
                "type": "array",
                "items": { "type": "string" }
              },
              "exportAllowed": { "type": "boolean" },
              "patientDeliveryAllowed": { "type": "boolean" }
            }
          },
          "patientPhotoProtocol": {
            "type": "object",
            "description": "Safe backend contract for doctor-selected patient photo/protocol metadata. It never exposes raw files, object storage paths, signed URLs, tokens, or physician-only text.",
            "properties": {
              "brainstormTask": { "type": "string", "enum": ["SD-MF-046"] },
              "status": {
                "type": "string",
                "enum": ["metadata_ready_backend_blocked", "blocked"]
              },
              "readyForBackendContract": { "type": "boolean" },
              "selectedPhotoCount": { "type": "integer" },
              "counts": {
                "type": "object",
                "properties": {
                  "selectedPhotos": { "type": "integer" },
                  "overviewPhotos": { "type": "integer" },
                  "dermoscopyPhotos": { "type": "integer" },
                  "reportAttachments": { "type": "integer" }
                }
              },
              "missing": {
                "type": "array",
                "items": { "type": "string" }
              },
              "deliveryBoundary": {
                "type": "object",
                "properties": {
                  "patientDeliveryAllowed": { "type": "boolean" },
                  "rawFilesExposed": { "type": "boolean" },
                  "signedUrlsIssued": { "type": "boolean" },
                  "storagePathsExposed": { "type": "boolean" },
                  "tokensExposed": { "type": "boolean" },
                  "physicianTextExposed": { "type": "boolean" },
                  "requiresSelfHostedFileProxy": { "type": "boolean" },
                  "requiresReleaseAudit": { "type": "boolean" },
                  "requiresRevoke": { "type": "boolean" },
                  "requiresIdentityCheck": { "type": "boolean" }
                }
              }
            }
          },
          "productBoundary": {
            "type": "object",
            "properties": {
              "managedRuntimeDependency": { "type": "string", "enum": ["none"] },
              "managedDatabaseDependency": { "type": "string", "enum": ["none"] },
              "externalRuntimeCalls": { "type": "boolean" },
              "rawPatientDataInReport": { "type": "boolean" }
            }
          }
        }
      },
      "PatientPhotoProtocolRelease": {
        "type": "object",
        "description": "Metadata-only release/revoke ledger. It never exposes raw files, storage paths, signed URLs, access tokens, object storage identifiers, or physician-only text.",
        "properties": {
          "id": { "type": "string" },
          "clinicId": { "type": ["string", "null"] },
          "patientId": { "type": ["string", "null"] },
          "visitId": { "type": ["string", "null"] },
          "reportId": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["blocked", "prepared", "revoked"] },
          "selectedPhotoCount": { "type": "integer" },
          "counts": {
            "type": "object",
            "properties": {
              "selectedPhotos": { "type": "integer" },
              "overviewPhotos": { "type": "integer" },
              "dermoscopyPhotos": { "type": "integer" },
              "reportAttachments": { "type": "integer" }
            }
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preparedAt": { "type": ["string", "null"] },
          "revokedAt": { "type": ["string", "null"] },
          "revokeReason": { "type": ["string", "null"] },
          "expiresAt": { "type": ["string", "null"] },
          "deliveryBoundary": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean" },
              "rawFilesExposed": { "type": "boolean" },
              "signedUrlsIssued": { "type": "boolean" },
              "storagePathsExposed": { "type": "boolean" },
              "tokensExposed": { "type": "boolean" },
              "physicianTextExposed": { "type": "boolean" },
              "requiresSelfHostedFileProxy": { "type": "boolean" },
              "requiresReleaseAudit": { "type": "boolean" },
              "requiresRevoke": { "type": "boolean" },
              "requiresIdentityCheck": { "type": "boolean" },
              "requiresRetentionPolicy": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
