{
  "openapi": "3.1.0",
  "info": {
    "title": "Dermatologist Pro self-hosted API",
    "version": "5N-patient-portal",
    "description": "Stage 5N production patient portal read contracts. The backend is self-hosted, PostgreSQL-owned, and has no managed runtime/database dependency."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "PatientPortalPhotoProtocol": {
        "type": "object",
        "description": "Metadata-only patient photo protocol. Files, storage paths, temporary links, tokens, and doctor-only text are not exposed.",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "reportId": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["prepared", "revoked"] },
          "accessStatus": { "type": "string" },
          "selectedPhotoCount": { "type": "integer", "minimum": 0 },
          "counts": { "type": "object" },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" },
          "preparedAt": { "type": ["string", "null"], "format": "date-time" },
          "revokedAt": { "type": ["string", "null"], "format": "date-time" },
          "patientSafeTextAvailable": { "type": "boolean" },
          "auditTrail": {
            "type": "array",
            "description": "Patient-safe audit summary derived from release metadata. Raw audit payloads, correlation ids, actor ids, and revoke reasons are not exposed.",
            "items": {
              "type": "object",
              "properties": {
                "kind": { "type": "string", "enum": ["prepared", "expires", "revoked", "event"] },
                "label": { "type": "string" },
                "occurredAt": { "type": ["string", "null"], "format": "date-time" }
              }
            }
          },
          "deliveryBoundary": {
            "type": "object",
            "properties": {
              "patientDeliveryAllowed": { "type": "boolean", "const": false },
              "rawFilesExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "tokensExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false },
              "fileProxyReady": { "type": "boolean" },
              "requiresIdentityCheck": { "type": "boolean" },
              "requiresRetentionPolicy": { "type": "boolean" },
              "requiresApprovedPatientCopy": { "type": "boolean" }
            }
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sequence": { "type": "integer", "minimum": 1 },
                "kind": { "type": "string" },
                "contentType": { "type": ["string", "null"] },
                "capturedAt": { "type": ["string", "null"], "format": "date-time" },
                "lesionLabel": { "type": ["string", "null"] },
                "bodyZone": { "type": ["string", "null"] },
                "bodySurface": { "type": ["string", "null"] },
                "previewAvailable": { "type": "boolean", "const": false }
              }
            }
          }
        }
      },
      "PatientPortalPhotoProtocolAccessExchange": {
        "type": "object",
        "description": "Metadata-only result of exchanging a patient-provided access credential for a backend session boundary. Raw credentials, credential hashes/fingerprints, raw session identifiers, session hashes/fingerprints, QR values, storage paths, signed URLs, and doctor-only text are not exposed.",
        "properties": {
          "visitId": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["confirmed", "denied"] },
          "accessStatus": { "type": "string" },
          "deniedReason": { "type": ["string", "null"] },
          "sessionExpiresAt": { "type": ["string", "null"], "format": "date-time" },
          "sessionBoundary": {
            "type": "object",
            "properties": {
              "sessionEstablished": { "type": "boolean" },
              "rawCredentialExposed": { "type": "boolean", "const": false },
              "credentialHashExposed": { "type": "boolean", "const": false },
              "credentialFingerprintExposed": { "type": "boolean", "const": false },
              "rawSessionIdExposed": { "type": "boolean", "const": false },
              "sessionHashExposed": { "type": "boolean", "const": false },
              "sessionFingerprintExposed": { "type": "boolean", "const": false },
              "qrTokenExposed": { "type": "boolean", "const": false },
              "signedUrlsIssued": { "type": "boolean", "const": false },
              "storagePathsExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false }
            }
          }
        }
      },
      "PatientPortalHistory": {
        "type": "object",
        "description": "Patient-safe longitudinal lesion history with comparison operations and access-session governance aggregates. Diagnosis, doctor-only text, raw files, storage paths, temporary links, and tokens are not exposed.",
        "properties": {
          "clinic": {
            "type": "object",
            "properties": {
              "id": { "type": ["string", "null"] },
              "slug": { "type": ["string", "null"] },
              "name": { "type": ["string", "null"] }
            }
          },
          "lesions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "bodyZone": { "type": ["string", "null"] },
                "bodySurface": { "type": ["string", "null"] },
                "status": { "type": "string" },
                "stateLabel": { "type": "string" },
                "firstSeenAt": { "type": ["string", "null"], "format": "date-time" },
                "checkedAt": { "type": ["string", "null"], "format": "date-time" },
                "snapshotCount": { "type": "integer", "minimum": 0 },
                "comparableSnapshotCount": { "type": "integer", "minimum": 0 },
                "nextStep": { "type": "string" },
                "comparisonState": { "type": "string" }
              }
            }
          },
          "timeline": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "visitId": { "type": ["string", "null"] },
                "visitDate": { "type": ["string", "null"], "format": "date-time" },
                "visitStatus": { "type": "string" },
                "stateLabel": { "type": "string" },
                "clinicName": { "type": ["string", "null"] },
                "summary": { "type": ["string", "null"] },
                "observedCount": { "type": "integer", "minimum": 0 },
                "snapshotCount": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "retentionGovernance": {
            "type": "object",
            "properties": {
              "releasesTotal": { "type": "integer", "minimum": 0 },
              "retentionApproved": { "type": "integer", "minimum": 0 },
              "patientCopyApproved": { "type": "integer", "minimum": 0 },
              "fileProxyEnabled": { "type": "integer", "minimum": 0 },
              "expiresConfigured": { "type": "integer", "minimum": 0 },
              "policyReady": { "type": "integer", "minimum": 0 },
              "status": { "type": "string", "enum": ["no_releases", "policy_in_progress", "policy_ready"] }
            }
          },
          "comparisonOperations": {
            "type": "object",
            "properties": {
              "lesionsTotal": { "type": "integer", "minimum": 0 },
              "readyForDoctorReview": { "type": "integer", "minimum": 0 },
              "requiresNextCapture": { "type": "integer", "minimum": 0 },
              "visitsWithComparableSeries": { "type": "integer", "minimum": 0 },
              "comparableCoveragePercent": { "type": "integer", "minimum": 0, "maximum": 100 },
              "status": { "type": "string", "enum": ["no_series", "needs_capture", "partial_ready", "ready_for_review"] },
              "doctorReviewRequired": { "type": "boolean", "const": true }
            }
          },
          "sessionLifecycle": {
            "type": "object",
            "properties": {
              "preparedAccessWindows": { "type": "integer", "minimum": 0 },
              "revokedAccessWindows": { "type": "integer", "minimum": 0 },
              "activeAccessWindows": { "type": "integer", "minimum": 0 },
              "expiringIn24h": { "type": "integer", "minimum": 0 },
              "expiredAccessWindows": { "type": "integer", "minimum": 0 },
              "missingExpiry": { "type": "integer", "minimum": 0 },
              "identityCheckEnabled": { "type": "integer", "minimum": 0 },
              "policyReadyAccessWindows": { "type": "integer", "minimum": 0 },
              "status": { "type": "string", "enum": ["no_access_windows", "governance_attention", "governance_ready"] },
              "sessionBoundary": {
                "type": "object",
                "properties": {
                  "temporaryCredentialsExposed": { "type": "boolean", "const": false },
                  "qrSessionExposed": { "type": "boolean", "const": false },
                  "rawTokensExposed": { "type": "boolean", "const": false }
                }
              }
            }
          },
          "longitudinalBoundary": {
            "type": "object",
            "properties": {
              "comparisonRequiresDoctorReview": { "type": "boolean", "const": true },
              "clinicalDecisionExposed": { "type": "boolean", "const": false },
              "rawFilesExposed": { "type": "boolean", "const": false },
              "doctorOnlyTextExposed": { "type": "boolean", "const": false }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/me/portal": {
      "get": {
        "summary": "Read the linked patient portal overview",
        "description": "Returns the authenticated patient user's own safe portal overview: profile, next appointment, patient-safe reports, and reminders.",
        "responses": {
          "200": {
            "description": "Patient portal overview"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Only patient role may read this endpoint"
          }
        }
      }
    },
    "/api/v1/me/history": {
      "get": {
        "summary": "Read patient-safe lesion history",
        "description": "Returns a longitudinal patient-safe history: lesion list, visit timeline, comparison-operations aggregates, and access-session governance counters. Diagnosis, doctor-only text, raw files, storage paths, temporary links, and tokens are not exposed.",
        "responses": {
          "200": {
            "description": "Patient-safe lesion history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientPortalHistory"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Only patient role may read this endpoint"
          }
        }
      }
    },
    "/api/v1/me/reports/{reportId}": {
      "get": {
        "summary": "Read one patient-safe report",
        "description": "Returns only patient_safe_text for a report linked to the authenticated patient account. Physician-only report fields are not exposed.",
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient-safe report"
          },
          "400": {
            "description": "Invalid report identifier"
          },
          "404": {
            "description": "Report not found in linked patient scope"
          }
        }
      }
    },
    "/api/v1/me/photo-protocols/{visitId}": {
      "get": {
        "summary": "Read one patient-safe photo protocol",
        "description": "Returns metadata for a prepared or revoked photo protocol linked to the authenticated patient account. The response is count and descriptor only; files, storage paths, temporary links, tokens, and doctor-only text are not exposed.",
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patient-safe photo protocol metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientPortalPhotoProtocol"
                }
              }
            }
          },
          "400": {
            "description": "Invalid visit identifier"
          },
          "404": {
            "description": "Photo protocol is not available in linked patient scope"
          }
        }
      }
    },
    "/api/v1/me/photo-protocols/{visitId}/access/exchange": {
      "post": {
        "summary": "Confirm patient photo-protocol access credential",
        "description": "Verifies a patient-provided credential against backend-owned hashes and creates a server-side session boundary. The response never exposes the raw credential, credential hash/fingerprint, raw session identifier, session hash/fingerprint, QR value, storage path, signed URL, or doctor-only text.",
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["credential"],
                "properties": {
                  "credential": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 512,
                    "writeOnly": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access credential confirmed; backend session boundary is ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientPortalPhotoProtocolAccessExchange"
                }
              }
            }
          },
          "403": {
            "description": "Credential could not be confirmed"
          },
          "410": {
            "description": "Photo protocol access was revoked or expired"
          },
          "423": {
            "description": "Photo protocol access policy, consent, proxy, or retention gate blocks exchange"
          },
          "503": {
            "description": "Credential/session pepper is not configured"
          }
        }
      }
    },
    "/api/v1/me/photo-protocols/{visitId}/photos/{sequence}/download": {
      "get": {
        "summary": "Stream one patient photo through the backend proxy",
        "description": "Streams photo bytes only when the authenticated patient is linked to the visit, a prepared release exists, the backend proxy flag is enabled, consent is present, retention policy is approved, and the release expiry is still valid. The API does not expose storage paths, object identifiers, signed links, access tokens, or doctor-only text.",
        "parameters": [
          {
            "name": "visitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "sequence",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Photo bytes streamed through the self-hosted backend proxy",
            "content": {
              "image/jpeg": { "schema": { "type": "string", "format": "binary" } },
              "image/png": { "schema": { "type": "string", "format": "binary" } },
              "image/webp": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "400": {
            "description": "Invalid visit or photo sequence"
          },
          "410": {
            "description": "Photo protocol access was revoked or expired"
          },
          "423": {
            "description": "Photo protocol proxy is blocked until backend, consent, and retention gates pass"
          }
        }
      }
    }
  }
}
