{
  "openapi": "3.0.3",
  "info": {
    "title": "Dermatolog Pro Self-hosted Leads/Appointments API",
    "version": "5K-leads-appointments-contracts"
  },
  "paths": {
    "/api/v1/leads/appointments": {
      "get": {
        "summary": "List local lead intake and visit-derived appointments",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "leadStatus", "in": "query", "schema": { "type": "string", "enum": ["new", "qualified", "booked", "lost"] } },
          { "name": "appointmentStatus", "in": "query", "schema": { "type": "string", "enum": ["planned", "confirmed", "completed", "cancelled"] } },
          { "name": "dateFrom", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "dateTo", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "search", "in": "query", "schema": { "type": "string", "maxLength": 120 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Lead and appointment overview from local PostgreSQL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeadsAppointmentsResponse"
                }
              }
            }
          },
          "401": { "description": "Authentication required" },
          "403": { "description": "Forbidden" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LeadsAppointmentsResponse": {
        "type": "object",
        "required": ["stage", "source", "kpis", "leads", "appointments"],
        "properties": {
          "stage": { "type": "string", "enum": ["5K"] },
          "source": { "type": "string", "enum": ["postgres"] },
          "kpis": { "$ref": "#/components/schemas/LeadsAppointmentsKpis" },
          "leads": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LeadOverviewItem" }
          },
          "appointments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AppointmentOverviewItem" }
          },
          "filters": { "type": "object" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "correlationId": { "type": "string" }
        }
      },
      "LeadsAppointmentsKpis": {
        "type": "object",
        "properties": {
          "leadsTotal": { "type": "integer" },
          "newLeads": { "type": "integer" },
          "qualifiedLeads": { "type": "integer" },
          "bookedLeads": { "type": "integer" },
          "plannedAppointments": { "type": "integer" },
          "completedAppointments": { "type": "integer" }
        }
      },
      "LeadOverviewItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "clinicId": { "type": "string", "nullable": true },
          "patientId": { "type": "string", "nullable": true },
          "source": { "type": "string" },
          "status": { "type": "string" },
          "safeSummary": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time", "nullable": true },
          "patient": { "type": "object" },
          "clinic": { "type": "object" }
        }
      },
      "AppointmentOverviewItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "visitId": { "type": "string" },
          "clinicId": { "type": "string", "nullable": true },
          "patientId": { "type": "string", "nullable": true },
          "doctorUserId": { "type": "string", "nullable": true },
          "status": { "type": "string" },
          "channel": { "type": "string" },
          "slotAt": { "type": "string", "format": "date-time", "nullable": true },
          "chiefComplaint": { "type": "string", "nullable": true },
          "patient": { "type": "object" },
          "clinic": { "type": "object" }
        }
      }
    }
  }
}
