{
  "openapi": "3.1.0",
  "info": {
    "title": "Dermatolog Pro Self-hosted Admin Management API",
    "version": "6A"
  },
  "paths": {
    "/api/v1/admin/users": {
      "get": {
        "operationId": "listAdminUsers",
        "summary": "List real self-hosted users from PostgreSQL"
      },
      "post": {
        "operationId": "createAdminUser",
        "summary": "Create a user and role binding in PostgreSQL"
      }
    },
    "/api/v1/admin/users/{userId}/role": {
      "patch": {
        "operationId": "assignAdminUserRole",
        "summary": "Assign an additional role to a self-hosted user"
      }
    },
    "/api/v1/admin/users/{userId}/disable": {
      "patch": {
        "operationId": "disableAdminUser",
        "summary": "Disable a self-hosted user account"
      }
    },
    "/api/v1/admin/users/{userId}/reactivate": {
      "patch": {
        "operationId": "reactivateAdminUser",
        "summary": "Reactivate a self-hosted user account"
      }
    },
    "/api/v1/admin/users/{userId}/role-status": {
      "patch": {
        "operationId": "setAdminUserRoleStatus",
        "summary": "Disable or reactivate one role binding without deleting the user"
      }
    },
    "/api/v1/admin/clinics": {
      "get": {
        "operationId": "listAdminClinics",
        "summary": "List real clinics from PostgreSQL"
      },
      "post": {
        "operationId": "createAdminClinic",
        "summary": "Create a clinic in PostgreSQL"
      }
    },
    "/api/v1/admin/clinics/{clinicId}": {
      "patch": {
        "operationId": "updateAdminClinic",
        "summary": "Update clinic identity fields"
      },
      "delete": {
        "operationId": "deleteEmptyAdminClinic",
        "summary": "Delete an empty mistaken clinic with no linked records"
      }
    },
    "/api/v1/admin/clinics/{clinicId}/status": {
      "patch": {
        "operationId": "setAdminClinicStatus",
        "summary": "Suspend, reactivate, or archive a clinic or private practice"
      }
    },
    "/api/v1/admin/private-practices": {
      "post": {
        "operationId": "createAdminPrivatePractice",
        "summary": "Create a private practice clinic and assign the owner as clinic admin and private dermatologist"
      }
    },
    "/api/v1/admin/doctors": {
      "get": {
        "operationId": "listAdminDoctors",
        "summary": "List doctors and private dermatologists"
      },
      "post": {
        "operationId": "createAdminDoctor",
        "summary": "Create a doctor or private dermatologist"
      }
    },
    "/api/v1/admin/analytics": {
      "get": {
        "operationId": "getAdminAnalytics",
        "summary": "Read production aggregate statistics without patient rows"
      }
    },
    "/api/v1/admin/services": {
      "get": {
        "operationId": "listAdminClinicServices",
        "summary": "List clinic service catalog rows inside the administrator scope"
      },
      "post": {
        "operationId": "createAdminClinicService",
        "summary": "Create a clinic service catalog row"
      }
    },
    "/api/v1/admin/services/{serviceId}": {
      "patch": {
        "operationId": "updateAdminClinicService",
        "summary": "Update a clinic service catalog row inside the administrator scope"
      }
    },
    "/api/v1/admin/audit-events": {
      "get": {
        "operationId": "listAdminAuditEvents",
        "summary": "List sanitized production audit events for system administrators"
      }
    },
    "/api/v1/admin/service-keys": {
      "get": {
        "operationId": "listAdminServiceKeys",
        "summary": "List masked service access keys without returning secret values"
      },
      "post": {
        "operationId": "createAdminServiceKey",
        "summary": "Create a service access key and return its secret value once"
      }
    },
    "/api/v1/admin/service-keys/{keyId}/rotate": {
      "patch": {
        "operationId": "rotateAdminServiceKey",
        "summary": "Rotate a service access key and return its new secret value once"
      }
    },
    "/api/v1/admin/service-keys/{keyId}/revoke": {
      "patch": {
        "operationId": "revokeAdminServiceKey",
        "summary": "Revoke a service access key without returning secret values"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [{ "bearerAuth": [] }]
}
