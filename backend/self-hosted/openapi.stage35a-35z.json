{
  "openapi": "3.1.0",
  "info": {
    "title": "Dermatolog Pro Self-Hosted Clinical Follow-Up SOP Governance Evidence Reconciliation Closure Receipt Archive Closure Receipt Handoff",
    "version": "35A-35Z-clinical-followup-sop-policy-governance-evidence-reconciliation-closure-receipt-archive-closure-receipt-handoff",
    "description": "Stage 35A-35Z local SOP policy governance evidence reconciliation closure receipt archive closure receipt handoff endpoints for the self-hosted product boundary."
  },
  "servers": [{ "url": "/" }],
  "paths": {
    "/api/v1/clinical/follow-ups/sop-policy-governance-evidence-reconciliation-closure-receipt-archive-closure-receipt-handoff/summary": {
      "get": {
        "summary": "Read local SOP policy governance evidence reconciliation closure receipt archive closure receipt handoff summary",
        "operationId": "getClinicalFollowUpSopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffSummary",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Local archive closure receipt handoff summary.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item"],
                  "properties": {
                    "stage": { "const": "35A-35Z" },
                    "source": { "const": "postgres" },
                    "item": { "$ref": "#/components/schemas/ArchiveClosureReceiptHandoffSummary" },
                    "generatedAt": { "type": "string" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/clinical/follow-ups/{followUpId}/sop-policy-governance-evidence-reconciliation-closure-receipt-archive-closure-receipt-handoff": {
      "patch": {
        "summary": "Update local SOP policy governance evidence reconciliation closure receipt archive closure receipt handoff",
        "operationId": "updateClinicalFollowUpSopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoff",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "followUpId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ArchiveClosureReceiptHandoffUpdate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated follow-up with local archive closure receipt handoff fields.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["stage", "source", "item"],
                  "properties": {
                    "stage": { "const": "35A-35Z" },
                    "source": { "const": "postgres" },
                    "item": { "$ref": "#/components/schemas/ArchiveClosureReceiptHandoffFollowUp" },
                    "generatedAt": { "type": "string" },
                    "correlationId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ArchiveClosureReceiptHandoffState": {
        "type": "string",
        "enum": ["not_started", "ready", "handed_off", "handoff_exception", "needs_rework"]
      },
      "ArchiveClosureReceiptHandoffSummary": {
        "type": "object",
        "required": [
          "totalFollowUps",
          "archiveClosureReceiptHandoffReady",
          "needsArchiveClosureReceiptHandoff",
          "handedOffArchiveClosureReceipts",
          "archiveClosureReceiptHandoffExceptions",
          "archiveClosureReceiptHandoffNeedsRework",
          "receivedArchiveClosureReceipts",
          "closedLocalArchives",
          "localGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffEvents"
        ],
        "properties": {
          "totalFollowUps": { "type": "integer" },
          "archiveClosureReceiptHandoffReady": { "type": "integer" },
          "needsArchiveClosureReceiptHandoff": { "type": "integer" },
          "handedOffArchiveClosureReceipts": { "type": "integer" },
          "archiveClosureReceiptHandoffExceptions": { "type": "integer" },
          "archiveClosureReceiptHandoffNeedsRework": { "type": "integer" },
          "receivedArchiveClosureReceipts": { "type": "integer" },
          "closedLocalArchives": { "type": "integer" },
          "localGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffEvents": { "type": "integer" },
          "source": { "const": "postgres" }
        }
      },
      "ArchiveClosureReceiptHandoffUpdate": {
        "type": "object",
        "properties": {
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffState": {
            "$ref": "#/components/schemas/ArchiveClosureReceiptHandoffState"
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffNote": {
            "type": ["string", "null"],
            "maxLength": 2000
          }
        },
        "anyOf": [
          { "required": ["sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffState"] },
          { "required": ["sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffNote"] }
        ]
      },
      "ArchiveClosureReceiptHandoffFollowUp": {
        "type": "object",
        "required": ["id", "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffState"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffState": {
            "$ref": "#/components/schemas/ArchiveClosureReceiptHandoffState"
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandoffNote": {
            "type": ["string", "null"]
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptHandedOffAt": {
            "type": ["string", "null"]
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureReceiptState": {
            "type": "string",
            "enum": ["not_started", "ready", "received", "receipt_exception", "needs_rework"]
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveClosureState": {
            "type": "string",
            "enum": ["not_started", "ready", "closed", "closure_exception", "needs_rework"]
          },
          "sopPolicyGovernanceEvidenceReconciliationClosureReceiptArchiveReadinessState": {
            "type": "string",
            "enum": ["not_started", "ready", "archived", "archive_exception", "needs_rework"]
          }
        }
      }
    }
  }
}
