#!/usr/bin/env sh
# Pre-push: блокирует deno.lock и сканирует staged + изменённые файлы doctor-контекста.

node scripts/check-no-deno-locks.mjs
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Push blocked: generated deno.lock files present."
  echo ""
  exit $status
fi

node scripts/scan-doctor-forbidden.mjs --changed --quiet
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Push заблокирован."
  echo "  Подробный отчёт: file://$(pwd)/reports/doctor-hygiene/scan-report.md"
  echo "  Команда: npm run scan:doctor"
  echo ""
  exit $status
fi
exit 0
