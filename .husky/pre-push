#!/usr/bin/env sh
# Pre-push: сканирует staged + изменённые файлы doctor-контекста.

echo ""
echo "▶ pre-push · doctor-hygiene-scan (changed)"
echo ""
node scripts/scan-doctor-forbidden.mjs --changed
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Push заблокирован."
  echo "  Подробный отчёт (после полного скана):"
  echo "    file://$(pwd)/reports/doctor-hygiene/scan-report.md"
  echo "  Команда: npm run scan:doctor"
  echo ""
  exit $status
fi
exit 0
