#!/usr/bin/env sh
# Pre-commit: сканирует только staged-файлы doctor-контекста (короткий вывод).

node scripts/scan-doctor-forbidden.mjs --staged --quiet
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Коммит заблокирован."
  echo "  Подробный отчёт: file://$(pwd)/reports/doctor-hygiene/scan-report.md"
  echo "  Команды:"
  echo "    npm run scan:doctor      # пересобрать отчёт"
  echo "    git commit --no-verify   # обойти (не рекомендуется)"
  echo ""
  exit $status
fi
exit 0
