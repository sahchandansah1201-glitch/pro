#!/usr/bin/env sh
# Pre-commit: блокирует коммит при наличии запрещённых паттернов в doctor-контексте.

echo ""
echo "▶ pre-commit · doctor-hygiene-scan"
echo ""
node scripts/scan-doctor-forbidden.mjs
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Коммит заблокирован. Исправьте находки выше или используйте --no-verify (не рекомендуется)."
  echo ""
  exit $status
fi
exit 0
