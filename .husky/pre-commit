#!/usr/bin/env sh
# Pre-commit: сканирует только staged-файлы из doctor-контекста.

echo ""
echo "▶ pre-commit · doctor-hygiene-scan (staged)"
echo ""
node scripts/scan-doctor-forbidden.mjs --staged
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Коммит заблокирован. Исправьте находки выше или используйте --no-verify (не рекомендуется)."
  echo ""
  exit $status
fi
exit 0
