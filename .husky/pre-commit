#!/usr/bin/env sh
# Pre-commit: блокирует deno.lock и сканирует staged-файлы doctor-контекста.

node scripts/check-no-deno-locks.mjs
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Commit blocked: generated deno.lock files present."
  echo ""
  exit $status
fi

node scripts/scan-doctor-forbidden.mjs --staged --quiet
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "✗ Коммит заблокирован."
  echo "  Подробный отчёт: file://$(pwd)/reports/doctor-hygiene/scan-report.md"
  echo "  Команды:"
  echo "    npm run scan:doctor      # пересобрать отчёт"
  echo "    git commit --no-verify   # обойти (не рекомендуется)"
  echo ""
  exit $status
fi
exit 0
