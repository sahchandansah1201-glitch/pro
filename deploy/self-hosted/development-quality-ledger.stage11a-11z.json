  "qualityRules": [
    {
      "id": "no_memory_only_scope",
      "severity": "critical",
      "rule": "Stage scope must be derived from repository files, not chat memory alone."
    },
    {
      "id": "x2_no_shrink",
      "severity": "critical",
      "rule": "Normal batches after Stage 10A-10Z must not shrink below 26 related stages without a documented exception."
    },
    {
      "id": "defect_requires_prevention",
      "severity": "critical",
      "rule": "Every repeated or newly found defect must be recorded with a prevention rule before Lovable handoff."
    },
    {
      "id": "preflight_all_alignment",
      "severity": "high",
      "rule": "New stage preflights must be present in preflight-all and preflight-all tests."
    },
    {
      "id": "old_guard_compatibility",
      "severity": "high",
      "rule": "When expanding hypotheses into larger batches, preserve older guard markers as historical markers until those guards are intentionally migrated."
    },
    {
      "id": "no_temp_artifacts",
      "severity": "high",
      "rule": "Temporary output directories and generated lock files must not enter Pull requests."
    },
    {
      "id": "merge_before_lovable",
      "severity": "critical",
      "rule": "Lovable sync prompt must be sent only after merge into main and local main verification."
    }
  ],
