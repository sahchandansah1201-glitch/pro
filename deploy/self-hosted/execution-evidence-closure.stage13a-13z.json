  "closureRules": [
    {
      "id": "closure_not_assumption",
      "severity": "critical",
      "rule": "A stage closure is invalid unless the repository contains the manifest, script, guard, docs, workflow, project-memory updates, and passing commands."
    },
    {
      "id": "prompt_after_merge_only",
      "severity": "critical",
      "rule": "A Lovable prompt is valid only after the Pull request has been merged into main and local main has been verified."
    },
    {
      "id": "previous_evidence_regression",
      "severity": "critical",
      "rule": "A closure batch must run the previous evidence batch preflight before handoff."
    },
    {
      "id": "next_batch_handoff_generated",
      "severity": "critical",
      "rule": "The next batch hypothesis must be generated in project memory before the current batch is handed off."
    },
    {
      "id": "checks_before_ready",
      "severity": "critical",
      "rule": "The Pull request must not be marked ready until local preflight and GitHub checks are green."
    },
    {
      "id": "sync_mismatch_diagnosed",
      "severity": "high",
      "rule": "If Lovable cannot see files, diagnose merged main, local main, repository connection, branch, and webhook state before claiming a conflict."
    },
    {
      "id": "relative_artifact_links",
      "severity": "high",
      "rule": "Repository artifact links must stay relative so CI, local machines, and Lovable can resolve them."
    },
    {
      "id": "no_runtime_coupling",
      "severity": "high",
      "rule": "Closure evidence must not introduce managed runtime, managed database, browser hardware, or external service coupling."
    },
    {
      "id": "previous_batch_regression_required",
      "severity": "high",
      "rule": "Normal x2 batches must include the previous batch preflight in the current preflight."
    },
    {
      "id": "lovable_prompt_source_locked",
      "severity": "critical",
      "rule": "The Lovable prompt must be derived from the manifest and not rewritten after merge."
    }
  ],
