{
  "stage": "8A-8C",
  "packageId": "stage8a-8c-crm-inbound-adapter",
  "title": "CRM inbound adapter implementation",
  "createdAt": "2026-05-21T12:30:00+03:00",
  "purpose": "Convert operator-owned CRM and advertising-source exports into the existing self-hosted Stage 5Q booking import contract without adding managed runtime dependency.",
  "includedStages": [
    {
      "id": "Stage 8A",
      "name": "CRM inbound adapter contract",
      "outcome": "Repository owns a mapping manifest and safe local export shape for CRM/ad-source records."
    },
    {
      "id": "Stage 8B",
      "name": "CRM export normalization",
      "outcome": "A deterministic CLI normalizes safe booking-request and available-slot records into the Stage 5Q import payload."
    },
    {
      "id": "Stage 8C",
      "name": "Safe import audit flow",
      "outcome": "The adapter renders a redacted audit summary, rejects unsafe values, and records no raw payload, token, URL, or external-system dependency."
    }
  ],
  "inputs": {
    "safeExportExample": "deploy/self-hosted/integrations/crm-inbound-export.stage8a.example.json",
    "mappingExample": "deploy/self-hosted/integrations/crm-inbound-mapping.stage8a.example.json"
  },
  "outputs": {
    "normalizedImportExample": "deploy/self-hosted/integrations/booking-import.stage8b.example.json",
    "auditReportFormat": "markdown",
    "targetEndpoint": "/api/v1/integrations/booking-imports"
  },
  "adapter": {
    "script": "scripts/stage8a-8c-crm-inbound-adapter.mjs",
    "exports": [
      "buildStage8A8CCrmAdapterPlan",
      "normalizeCrmInboundRecords",
      "buildStage5QImportPayloadFromCrmExport",
      "renderStage8A8CCrmInboundAdapterDryRun",
      "runStage8A8CCrmInboundAdapter"
    ],
    "mode": "offline-normalization",
    "networkCalls": false,
    "storesRawExternalPayload": false,
    "allowedSourceSystems": [
      "clinic_crm",
      "ads",
      "site",
      "manual",
      "other"
    ],
    "acceptedRecordKinds": [
      "booking_request",
      "available_slot"
    ]
  },
  "safetyPolicy": {
    "rejectsRawUrls": true,
    "rejectsTokens": true,
    "rejectsStoragePaths": true,
    "rejectsManagedRuntimeMarkers": true,
    "rejectsRawPatientNames": true,
    "auditContainsCountsOnly": true
  },
  "productBoundary": {
    "selfHostedBackend": true,
    "operatorOwnedConnectorProcess": true,
    "managedRuntimeDependency": "none",
    "managedDatabaseDependency": "none",
    "browserHardwareApis": false,
    "backendCallsExternalCrmRuntime": false,
    "browserCallsExternalCrmRuntime": false
  },
  "lovableSyncVerification": {
    "validOnlyAfterMergeToMain": true,
    "expectedConfirmation": "Confirmed: Stage 8A-8C synced from main, no conflicts.",
    "requiredFiles": [
      "deploy/self-hosted/integrations/crm-inbound-adapter.stage8a-8c.json",
      "deploy/self-hosted/integrations/crm-inbound-export.stage8a.example.json",
      "deploy/self-hosted/integrations/crm-inbound-mapping.stage8a.example.json",
      "deploy/self-hosted/integrations/booking-import.stage8b.example.json",
      "scripts/stage8a-8c-crm-inbound-adapter.mjs",
      "scripts/stage8a-8c-crm-inbound-adapter.test.mjs",
      "scripts/check-stage8a-8c-crm-inbound-adapter.mjs",
      "scripts/check-stage8a-8c-crm-inbound-adapter.test.mjs",
      "docs/backend/stage-8a-8c-crm-inbound-adapter.md",
      ".github/workflows/stage8a-8c-crm-inbound-adapter.yml"
    ],
    "requiredCommands": [
      "npm run test:stage8a-8c",
      "npm run check:stage8a-8c",
      "npm run adapter:stage8a-8c:dry-run",
      "npm run preflight:stage8a-8c",
      "npm run check:project-memory",
      "node scripts/check-no-deno-locks.mjs"
    ],
    "packageLockMustRemainUnchanged": true,
    "denoLockMustBeAbsent": true
  },
  "driftGuard": {
