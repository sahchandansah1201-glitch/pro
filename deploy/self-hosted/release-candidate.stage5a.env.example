# Stage 5A · self-hosted release candidate environment template.
# Copy this into the server deployment inventory. Do not commit real values.

APP_PORT=8080
PUBLIC_BASE_URL=https://dermatolog.example.test

# Backend runtime.
BACKEND_PORT=3001
CORS_ORIGINS=https://dermatolog.example.test
JWT_ISSUER=dermatolog-pro-self-hosted
JWT_SECRET=replace-me-with-64-random-characters
JWT_EXPIRES_IN_SECONDS=3600

# Operator-owned PostgreSQL. Keep this on the same server/network as the app.
POSTGRES_DB=dermatolog_pro
POSTGRES_USER=dermatolog
POSTGRES_PASSWORD=replace-me-postgres-password
DATABASE_URL=postgres://dermatolog:replace-me-postgres-password@postgres:5432/dermatolog_pro

# Operator-owned object storage. Local filesystem is the default release
# candidate mode; MinIO can remain private to the deployment network.
OBJECT_STORAGE_BUCKET=clinical-assets
OBJECT_STORAGE_LOCAL_DIR=/var/lib/dermatolog-pro/object-storage
OBJECT_STORAGE_ENDPOINT=http://object-storage:9000
MINIO_ROOT_USER=dermatolog_minio
MINIO_ROOT_PASSWORD=replace-me-minio-password
MINIO_CONSOLE_PORT=9001

# Local Device Bridge worker. This token is server/worker-only.
DEVICE_BRIDGE_WORKER_TOKEN=replace-me-with-64-random-characters-worker-token
SELF_HOSTED_API_BASE_URL=https://dermatolog.example.test

# Frontend build-time self-hosted API default.
VITE_SELF_HOSTED_API_BASE_URL=https://dermatolog.example.test

# Backup policy owned by the server operator.
BACKUP_ROOT=/var/backups/dermatolog-pro
BACKUP_RETENTION_DAYS=14

# Release boundary assertion.
THIRD_PARTY_MANAGED_SERVICES_REQUIRED=false
