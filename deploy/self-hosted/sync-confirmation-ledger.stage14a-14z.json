  "ledgerRules": [
    {
      "id": "sync_confirmation_not_memory",
      "severity": "critical",
      "rule": "A sync confirmation is valid only when it is recorded in repository evidence and tied to a merged main commit."
    },
    {
      "id": "main_before_confirmation",
      "severity": "critical",
      "rule": "Lovable confirmation requests must reference main after merge, not an unmerged branch."
    },
    {
      "id": "duplicate_ci_wait_required",
      "severity": "high",
      "rule": "If duplicate GitHub check runs exist, all required duplicates must reach success or skip before ready or merge."
    },
    {
      "id": "sync_delay_not_conflict",
      "severity": "critical",
      "rule": "A missing file in Lovable is classified as sync delay until merged main, local head, repository connection, and visible head are checked."
    },
    {
      "id": "previous_closure_regression",
      "severity": "critical",
      "rule": "Stage 14 must run the Stage 13 closure preflight before handoff."
    },
