      "rule": "Post-merge local main verification is required before any Lovable prompt is released."
    },
    {
      "id": "prompt_source_manifest",
      "severity": "high",
      "rule": "The Lovable prompt must be generated from this ledger manifest and must not be rewritten from memory."
    },
    {
      "id": "relative_artifact_links",
      "severity": "high",
      "rule": "Project-memory artifact links must remain repository-relative."
    },
    {
      "id": "no_runtime_coupling",
      "severity": "critical",
      "rule": "The sync ledger must not introduce managed runtime, managed database, browser hardware, or external service coupling."
    },
    {
