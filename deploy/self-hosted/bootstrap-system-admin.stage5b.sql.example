-- Stage 5B · first system_admin bootstrap template.
-- Generate a real file on the server with:
-- node scripts/stage5b-server-bootstrap.mjs admin-sql --email admin@example.com --password '<temporary-password>' --output /secure/path/bootstrap-system-admin.sql
--
-- Do not commit generated SQL. This checked-in file is a shape-only example.

begin;

insert into clinics (id, slug, name, timezone)
values (
  '10000000-0000-4000-8000-000000000001',
  'primary-clinic',
  'Dermatolog Pro Clinic',
  'Europe/Moscow'
)
on conflict (slug) do update
set name = excluded.name,
    updated_at = now();

-- Replace these placeholders only in a generated, local server-side copy.
-- password_hash must be generated by backend/self-hosted/auth-crypto.mjs.
with upserted_user as (
  insert into app_users (email, display_name, password_hash, disabled_at)
  values (
    'admin@example.invalid',
    'System Administrator',
    '$scrypt$REPLACE_WITH_GENERATED_HASH',
    null
  )
  on conflict (email) do update
  set display_name = excluded.display_name,
      password_hash = excluded.password_hash,
      disabled_at = null,
      updated_at = now()
  returning id
)
insert into user_roles (user_id, clinic_id, role)
select id, '10000000-0000-4000-8000-000000000001', 'system_admin'::app_role
from upserted_user
on conflict (user_id, clinic_id, role) do nothing;

insert into audit_log (
  clinic_id,
  actor_user_id,
  action,
  entity_type,
  correlation_id,
  metadata_json
)
values (
  '10000000-0000-4000-8000-000000000001',
  null,
  'stage5b.system_admin_bootstrap',
  'app_user',
  'stage5b-bootstrap',
  '{"role":"system_admin","source":"server-bootstrap"}'::jsonb
);

commit;
