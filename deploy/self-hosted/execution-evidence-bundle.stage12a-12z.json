  "evidenceSections": [
    {
      "id": "implementation",
      "title": "Implementation Evidence",
      "requiredEvidence": [
        "base commit",
        "branch name",
        "included stages",
        "owned files",
        "same-PR justification",
        "runtime boundary statement"
      ]
    },
    {
      "id": "diagnostics",
      "title": "Diagnostics Evidence",
      "requiredEvidence": [
        "defects found before handoff",
        "recurrence class",
        "fix applied",
        "prevention rule",
        "verification command",
        "worklog entry"
      ]
    },
    {
      "id": "verification",
      "title": "Verification Evidence",
      "requiredEvidence": [
        "stage tests",
        "stage guard",
        "stage report",
        "stage preflight",
        "previous-batch regression",
        "project-memory guard",
        "typecheck",
        "preflight-all dry-run",
        "no-deno-locks",
        "diff check"
      ]
    },
    {
      "id": "github",
      "title": "GitHub Evidence",
      "requiredEvidence": [
        "Pull request URL",
        "commit SHA",
        "check-run summary",
        "fallback method for API timeouts",
        "merge commit",
        "deleted branch status"
      ]
    },
    {
      "id": "lovable",
      "title": "Lovable Evidence",
      "requiredEvidence": [
        "prompt source file",
        "prompt blocked before merge",
        "post-merge local main check",
        "expected confirmation",
        "sync mismatch diagnostic steps",
        "next batch hypothesis"
      ]
    }
  ],
  "evidenceRules": [
    {
      "id": "evidence_not_assertion",
      "severity": "critical",
      "rule": "A handoff claim must point to repository evidence or a command output; chat memory alone is not enough."
    },
    {
      "id": "checks_before_ready",
      "severity": "critical",
      "rule": "A Pull request cannot be marked ready until local stage preflight and GitHub checks have both passed."
    },
    {
      "id": "merge_before_prompt",
      "severity": "critical",
      "rule": "Lovable prompt remains invalid until the Pull request is merged into main and local main is verified."
    },
    {
      "id": "defect_has_worklog",
      "severity": "high",
      "rule": "A detected defect must be recorded in WORKLOG with its recurrence class and prevention evidence."
    },
    {
      "id": "previous_batch_regression_required",
      "severity": "high",
      "rule": "A normal x2 batch must run the previous batch preflight before handoff."
    },
    {
      "id": "artifact_hygiene_required",
      "severity": "high",
      "rule": "Generated lock files and temporary dry-run outputs must be absent before commit."
    },
    {
      "id": "package_lock_unchanged",
      "severity": "high",
      "rule": "package-lock.json must remain unchanged unless dependency installation is the explicit scope."
    },
    {
      "id": "lovable_prompt_generated",
      "severity": "critical",
      "rule": "The Lovable prompt must be generated from the manifest, not rewritten manually after merge."
    }
  ],
  "requiredFiles": [
    "deploy/self-hosted/execution-evidence-bundle.stage12a-12z.json",
    "scripts/stage12a-12z-execution-evidence-bundle.mjs",
    "scripts/stage12a-12z-execution-evidence-bundle.test.mjs",
