  "ledgerRules": [
    {
      "id": "post_sync_confirmation_not_memory",
      "severity": "critical",
      "rule": "A post-sync confirmation is valid only when the repository records the confirmation phrase, merge commit, and verification commands."
    },
    {
      "id": "stage14_regression_required",
      "severity": "critical",
      "rule": "Stage 15 must run the Stage 14 preflight before handoff."
    },
    {
      "id": "main_verified_before_next_handoff",
      "severity": "critical",
      "rule": "Local main and origin main must match the merged Stage 15 commit before the Lovable prompt is released."
    },
    {
      "id": "lovable_prompt_replay_manifest",
      "severity": "high",
      "rule": "The Lovable prompt must be generated from the Stage 15 manifest and must replay the exact file and command checklist."
    },
    {
      "id": "duplicate_ci_wait_required",
      "severity": "high",
      "rule": "If duplicate GitHub check runs exist, all required duplicates must reach success or skip before ready or merge."
    },
    {
      "id": "sync_delay_not_conflict",
      "severity": "critical",
      "rule": "A missing file in Lovable is classified as sync delay until merged main, local head, remote head, repository connection, and visible head are checked."
    },
    {
      "id": "wrong_project_diagnostic_required",
      "severity": "high",
      "rule": "A mismatched Lovable response must be diagnosed as wrong project, wrong branch, stale mirror, or stale prompt before code changes are made."
    },
    {
      "id": "relative_artifact_links",
      "severity": "high",
      "rule": "Project-memory artifact links must remain repository-relative."
    },
    {
      "id": "no_runtime_coupling",
      "severity": "critical",
      "rule": "The handoff readiness packet must not introduce managed runtime, managed database, browser hardware, or external service coupling."
    },
    {
      "id": "next_batch_hypothesis_recorded",
      "severity": "critical",
      "rule": "Stage 16A-16Z must be recorded as a hypothesis until repository files define the next scope."
    }
  ],
