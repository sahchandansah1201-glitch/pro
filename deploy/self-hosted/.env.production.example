# Stage 4L · self-hosted production environment template.
# Copy to `.env.production` on the server. Do not commit real values.

APP_PORT=8080

# Frontend production cutover. Required for real self-hosted auth.
# Without these keys the browser app stays in demo mode.
VITE_APP_MODE=production
VITE_SELF_HOSTED_API_BASE_URL=https://dermatolog.example.test

# Replace before deploy. Use a long generated value, not the local demo secret.
POSTGRES_PASSWORD=replace-me-postgres-password

OBJECT_STORAGE_BUCKET=clinical-assets

# Replace before deploy. At least 32 random characters.
JWT_SECRET=replace-me-with-64-random-characters
JWT_EXPIRES_IN_SECONDS=3600

# Replace before enabling a local Device Bridge worker. Never expose this in frontend env.
DEVICE_BRIDGE_WORKER_TOKEN=replace-me-with-64-random-characters-worker-token

# MinIO is included for future external object-storage migration and console
# inspection. The current backend-owned binary store uses the
# backend-object-storage volume.
MINIO_ROOT_USER=dermatolog_minio
MINIO_ROOT_PASSWORD=replace-me-minio-password
MINIO_CONSOLE_PORT=9001

# Local backup policy used by Stage 4L runbooks.
BACKUP_RETENTION_DAYS=14
